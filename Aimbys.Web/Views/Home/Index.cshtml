@model Aimbys.Web.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Sign in";
    Layout = "/Views/Shared/_LayoutMinimal.cshtml";

    // Re-create the React LandingPage roleConfig (id, label, desc,
    // accent colour, route hint). The ids match the AppRole values from
    // src/app/components/aimbys/LandingPage.tsx; the desc strings are
    // copied verbatim. accentClass maps to a CSS variable scope on the
    // tile so the React multi-colour treatment translates without a
    // proliferation of utility classes.
    var roles = new[]
    {
        new { Id = "superadmin", Label = "AIMBYS Super Admin",     Desc = "Platform & tenant management",         Accent = "violet" },
        new { Id = "institute",  Label = "Institute Administrator",Desc = "Institution & academic management",    Accent = "blue"   },
        new { Id = "teacher",    Label = "Teacher / Examiner",     Desc = "Paper generation & evaluation",        Accent = "sky"    },
        new { Id = "student",    Label = "Student / Candidate",    Desc = "Examination & result access",          Accent = "green"  }
    };

    // Stats + features mirror the React reference one-for-one so any
    // future copy edit in the React app can be ported back here line
    // by line.
    var stats = new[]
    {
        ("2,400+",      "Institutions"),
        ("1.2M+",       "Registered Users"),
        ("8,50,000+",   "Papers Generated"),
        ("42,000+",     "Exams Conducted")
    };

    var features = new[]
    {
        "Blueprint-based paper generation",
        "AI-assisted question tagging",
        "Multi-type question support (MCQ, Descriptive, Coding)",
        "Real-time exam monitoring & integrity",
        "Automated & manual evaluation workflows",
        "Role-based access with full audit trail",
        "National-scale analytics & reporting",
        "Compliance-ready with data governance"
    };

    var noRoleFlash = TempData[Aimbys.Web.Controllers.AccountController.NoRoleFlashKey] as string;
}

<div class="aimbys-landing">

    @* ---------- Left institutional panel ---------- *@
    @* Hidden below lg by Bootstrap utilities; on small screens the right-side
       login panel rides solo with a compact mobile header that lives just
       above this comment in the React reference. *@
    <aside class="aimbys-landing__hero d-none d-lg-flex flex-column">
        <header class="d-flex align-items-center justify-content-between px-4 px-xl-5 pt-4 pb-3 border-bottom border-white border-opacity-10">
            <div class="d-flex align-items-center gap-3">
                <span class="aimbys-logo-mark">A</span>
                <div class="lh-sm">
                    <div class="text-white fw-bold">AIMBYS Solutions</div>
                    <div class="small text-uppercase opacity-50" style="letter-spacing: 0.18em; font-size: 0.7rem;">
                        Assessment Platform v1
                    </div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2 small text-white-50">
                <span class="aimbys-pulse-dot" aria-hidden="true"></span>
                All Systems Operational
            </div>
        </header>

        <div class="flex-grow-1 px-4 px-xl-5 pt-4 pb-3">
            <span class="badge text-uppercase fw-semibold mb-3 aimbys-landing__hero-tag" style="letter-spacing: 0.14em;">
                <span aria-hidden="true">&#x1F6E1;</span>
                Government-Grade Secure Platform
            </span>
            <h1 class="text-white fw-black lh-1 mb-3 aimbys-landing__hero-title">
                National Assessment &amp;<br />
                <span class="aimbys-landing__hero-accent">Paper Generation</span><br />
                Ecosystem
            </h1>
            <p class="text-white-50 mb-4" style="max-width: 36rem;">
                A comprehensive, enterprise-grade platform for paper creation,
                examination conduct, evaluation, and advanced analytics &mdash;
                trusted by institutions across the country.
            </p>

            <div class="row row-cols-2 row-cols-xl-4 g-3 mb-4">
                @foreach (var (value, label) in stats)
                {
                    <div class="col">
                        <div class="aimbys-landing__stat text-center py-3 rounded">
                            <div class="text-white fw-black fs-5">@value</div>
                            <div class="small text-white-50 mt-1">@label</div>
                        </div>
                    </div>
                }
            </div>

            <ul class="list-unstyled row row-cols-1 row-cols-xl-2 g-2 mb-0">
                @foreach (var feature in features)
                {
                    <li class="col d-flex align-items-start gap-2">
                        <span class="aimbys-landing__check text-info-emphasis flex-shrink-0" aria-hidden="true">&#x2713;</span>
                        <span class="text-white-50 small lh-base">@feature</span>
                    </li>
                }
            </ul>
        </div>

        <footer class="d-flex flex-wrap align-items-center justify-content-between gap-3 px-4 px-xl-5 py-3 border-top border-white border-opacity-10 small text-white-50">
            <div class="d-flex flex-wrap gap-3">
                <span><span aria-hidden="true">&#x1F512;</span> ISO 27001 Certified</span>
                <span><span aria-hidden="true">&#x1F510;</span> 256-bit TLS Encryption</span>
                <span><span aria-hidden="true">&#x1F396;</span> CERT-In Compliant</span>
            </div>
            <span class="opacity-50">&copy; @DateTime.UtcNow.Year AIMBYS Solutions Pvt. Ltd.</span>
        </footer>
    </aside>

    @* ---------- Right login panel ---------- *@
    <section class="aimbys-landing__form d-flex flex-column">

        @* Mobile-only top brand strip — replaces the dark hero on phones. *@
        <div class="aimbys-landing__mobile-brand d-flex d-lg-none align-items-center gap-3 px-4 py-3">
            <span class="aimbys-logo-mark">A</span>
            <span class="text-white fw-bold">AIMBYS Solutions</span>
        </div>

        <div class="flex-grow-1 d-flex align-items-center justify-content-center px-3 px-md-5 py-4 py-md-5">
            <div class="w-100" style="max-width: 28rem;">
                <header class="mb-4">
                    <h2 class="fw-black mb-1" style="font-size: 1.75rem;">Secure Sign In</h2>
                    <p class="text-secondary small mb-0">
                        AIMBYS National Assessment Platform
                    </p>
                </header>

                @if (!string.IsNullOrEmpty(noRoleFlash))
                {
                    <div class="alert alert-warning d-flex align-items-start gap-2 small mb-4" role="alert">
                        <span aria-hidden="true">&#x26A0;&#xFE0F;</span>
                        <div>@noRoleFlash</div>
                    </div>
                }

                @* ---------- Step 1: role-pick ---------- *@
                @* The two-step UX from the React reference is implemented
                   without a page reload: the role tile sets a hidden
                   <input> via JS and reveals the credentials panel below.
                   Falling back to no-JS keeps the form usable; users
                   without JS see both panels and pick a role with a
                   plain radio while the credentials are always visible. *@
                <fieldset class="aimbys-landing__step" data-step="role" id="aimbys-step-role">
                    <legend class="form-label small fw-semibold text-uppercase text-secondary mb-3"
                            style="letter-spacing: 0.1em;">
                        Select Your Role
                    </legend>
                    <div class="d-grid gap-2">
                        @foreach (var role in roles)
                        {
                            <label class="aimbys-role-tile d-flex align-items-center gap-3 p-3 rounded border-2 bg-body"
                                   data-role="@role.Id"
                                   data-accent="@role.Accent"
                                   for="role-@role.Id">
                                <input class="form-check-input visually-hidden aimbys-role-tile__input"
                                       type="radio"
                                       name="SelectedRole"
                                       id="role-@role.Id"
                                       value="@role.Id"
                                       data-accent="@role.Accent" />
                                <span class="aimbys-role-tile__icon flex-shrink-0" aria-hidden="true">
                                    @switch (role.Id)
                                    {
                                        case "superadmin":
                                            <span>&#x1F6E1;</span>
                                            break;
                                        case "institute":
                                            <span>&#x1F310;</span>
                                            break;
                                        case "teacher":
                                            <span>&#x1F4DD;</span>
                                            break;
                                        case "student":
                                            <span>&#x1F4D6;</span>
                                            break;
                                    }
                                </span>
                                <span class="flex-grow-1 lh-sm">
                                    <span class="d-block fw-semibold aimbys-role-tile__label">@role.Label</span>
                                    <span class="d-block small text-secondary">@role.Desc</span>
                                </span>
                                <span class="aimbys-role-tile__chevron text-primary flex-shrink-0" aria-hidden="true">&rsaquo;</span>
                            </label>
                        }
                    </div>
                </fieldset>

                @* ---------- Step 2: credentials ---------- *@
                <form asp-controller="Account" asp-action="Login" method="post" novalidate
                      class="aimbys-landing__step mt-4" data-step="credentials" id="aimbys-step-credentials">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-semibold mb-1">Email</label>
                        <input asp-for="Email" class="form-control"
                               autocomplete="username"
                               placeholder="you@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label small fw-semibold mb-1">Password</label>
                        <div class="input-group aimbys-landing__password">
                            <input asp-for="Password"
                                   class="form-control"
                                   id="aimbys-password"
                                   autocomplete="current-password"
                                   placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" />
                            <button class="btn btn-outline-secondary" type="button"
                                    aria-controls="aimbys-password"
                                    aria-pressed="false"
                                    id="aimbys-toggle-password"
                                    aria-label="Show password">
                                <span aria-hidden="true">&#x1F441;</span>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center small mb-3">
                        <label class="form-check d-inline-flex align-items-center gap-2 mb-0">
                            <input class="form-check-input m-0" type="checkbox" asp-for="RememberMe" />
                            <span>Remember this device</span>
                        </label>
                        @* Forgot-password support lands with the
                           account-recovery surface in a later chunk; the
                           link is rendered today so the page matches the
                           React reference and tests for "the link
                           exists" stay green. *@
                        <a class="link-primary text-decoration-none"
                           asp-controller="Account" asp-action="Login">
                            Forgot password?
                        </a>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-semibold py-2 d-flex align-items-center justify-content-center gap-2">
                        <span aria-hidden="true">&#x1F510;</span>
                        Sign In Securely
                    </button>

                    <p class="small text-secondary text-center mt-3 mb-0">
                        Don't have an account?
                        <a asp-controller="Account" asp-action="Register">Register</a>
                    </p>
                </form>

                <div class="d-flex justify-content-center gap-4 mt-4 pt-3 border-top small text-secondary">
                    <span class="d-inline-flex flex-column align-items-center gap-1 text-center">
                        <span aria-hidden="true">&#x1F512;</span>
                        End-to-End Encrypted
                    </span>
                    <span class="d-inline-flex flex-column align-items-center gap-1 text-center">
                        <span aria-hidden="true">&#x1F6E1;</span>
                        CERT-In Compliant
                    </span>
                    <span class="d-inline-flex flex-column align-items-center gap-1 text-center">
                        <span aria-hidden="true">&#x1F4CB;</span>
                        Audit Logged
                    </span>
                </div>

                <div class="mt-3 small d-flex align-items-start gap-2 alert alert-warning mb-0" role="note">
                    <span aria-hidden="true">&#x26A0;&#xFE0F;</span>
                    This system is for authorized personnel only. All access
                    is logged and monitored.
                </div>
            </div>
        </div>
    </section>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/landing.js" asp-append-version="true"></script>
}
