@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.WebUtilities
@using Aimbys.Web.Models.UI
@model PaginationModel

@*
    Query-string-preserving pagination. Picks up every existing
    parameter from the current request (search filters, sorts) and
    re-emits them on each link with the page parameter swapped.
    Hidden when there's only one page so the partial is safe to
    render unconditionally.
*@

@functions {
    string PageUrl(HttpContext ctx, string pageQueryName, int page)
    {
        var existing = QueryHelpers.ParseQuery(ctx.Request.QueryString.Value ?? string.Empty);
        var pairs = new Dictionary<string, string?>();
        foreach (var kv in existing)
        {
            if (!string.Equals(kv.Key, pageQueryName, StringComparison.OrdinalIgnoreCase))
            {
                pairs[kv.Key] = kv.Value.ToString();
            }
        }
        pairs[pageQueryName] = page.ToString();
        return QueryHelpers.AddQueryString(ctx.Request.Path, pairs);
    }
}

@if (Model.TotalPages > 1)
{
    var current = Math.Clamp(Model.CurrentPage, 1, Model.TotalPages);

    // Render at most 7 page numbers around the current.
    var window = 3;
    var first = Math.Max(1, current - window);
    var last  = Math.Min(Model.TotalPages, current + window);

    <nav aria-label="Page navigation">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(current == 1 ? "disabled" : null)">
                <a class="page-link" href="@PageUrl(Context, Model.PageQueryName, current - 1)" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>

            @if (first > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@PageUrl(Context, Model.PageQueryName, 1)">1</a>
                </li>
                if (first > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }

            @for (var i = first; i <= last; i++)
            {
                <li class="page-item @(i == current ? "active" : null)">
                    <a class="page-link" href="@PageUrl(Context, Model.PageQueryName, i)"
                       aria-current="@(i == current ? "page" : null)">@i</a>
                </li>
            }

            @if (last < Model.TotalPages)
            {
                if (last < Model.TotalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item">
                    <a class="page-link" href="@PageUrl(Context, Model.PageQueryName, Model.TotalPages)">@Model.TotalPages</a>
                </li>
            }

            <li class="page-item @(current == Model.TotalPages ? "disabled" : null)">
                <a class="page-link" href="@PageUrl(Context, Model.PageQueryName, current + 1)" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
}
