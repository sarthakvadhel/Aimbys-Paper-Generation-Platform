@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@functions {
    static bool IsActive(ViewContext ctx, string controller, string action)
    {
        var c = ctx.RouteData.Values["controller"]?.ToString();
        var a = ctx.RouteData.Values["action"]?.ToString();
        return string.Equals(c, controller, StringComparison.OrdinalIgnoreCase)
            && string.Equals(a, action, StringComparison.OrdinalIgnoreCase);
    }

    static bool IsControllerActive(ViewContext ctx, string controller)
    {
        var c = ctx.RouteData.Values["controller"]?.ToString();
        return string.Equals(c, controller, StringComparison.OrdinalIgnoreCase);
    }
}
<header class="aimbys-header sticky-top">
    <nav class="navbar navbar-expand-lg" data-bs-theme="dark" aria-label="Primary navigation">
        <div class="container">
            <a class="navbar-brand d-inline-flex align-items-center gap-2"
               asp-controller="Home" asp-action="Index">
                <span class="aimbys-logo-mark" aria-hidden="true">A</span>
                <span class="d-inline-flex flex-column lh-1">
                    <span class="fw-bold">AIMBYS</span>
                    <span class="aimbys-brand-tagline text-uppercase opacity-75">Assessment Platform</span>
                </span>
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#aimbys-navbar"
                    aria-controls="aimbys-navbar" aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="aimbys-navbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link @(IsActive(ViewContext, "Home", "Index") ? "active" : null)"
                           aria-current="@(IsActive(ViewContext, "Home", "Index") ? "page" : null)"
                           asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(IsControllerActive(ViewContext, "Projects") ? "active" : null)"
                               aria-current="@(IsControllerActive(ViewContext, "Projects") ? "page" : null)"
                               asp-controller="Projects" asp-action="Index">Projects</a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link @(IsActive(ViewContext, "Home", "Privacy") ? "active" : null)"
                           aria-current="@(IsActive(ViewContext, "Home", "Privacy") ? "page" : null)"
                           asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </li>
                </ul>

                <div class="d-flex flex-column flex-lg-row gap-2 align-items-stretch align-items-lg-center">
                    <span class="aimbys-status d-inline-flex align-items-center gap-2 small text-light">
                        <span class="aimbys-pulse-dot" aria-hidden="true"></span>
                        All systems operational
                    </span>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </div>
    </nav>
</header>
