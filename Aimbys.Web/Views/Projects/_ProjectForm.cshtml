@model Aimbys.Web.ViewModels.Projects.ProjectFormViewModel

@{
    var action = Model.IsEdit ? "Edit" : "Create";
    var submitText = Model.IsEdit ? "Save changes" : "Create project";
}

<form asp-action="@action" asp-route-id="@(Model.IsEdit ? Model.Id.ToString() : null)"
      method="post" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="IsEdit" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"
         style="@(ViewContext.ModelState.IsValid ? "display:none;" : "")"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" autocomplete="off" autofocus
               maxlength="200" required />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="6"
                  maxlength="2000" placeholder="What is this project for?"></textarea>
        <span asp-validation-for="Description" class="text-danger small"></span>
        <div class="form-text">Optional. Up to 2,000 characters.</div>
    </div>

    @if (Model.IsEdit)
    {
        <div class="form-check mb-4">
            <input asp-for="IsArchived" class="form-check-input" />
            <label asp-for="IsArchived" class="form-check-label"></label>
            <div class="form-text">
                Archived projects are hidden from the default list but remain accessible.
            </div>
        </div>
    }

    <div class="d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">@submitText</button>
        <a class="btn btn-outline-secondary"
           asp-action="@(Model.IsEdit ? "Details" : "Index")"
           asp-route-id="@(Model.IsEdit ? Model.Id.ToString() : null)">Cancel</a>
    </div>
</form>
