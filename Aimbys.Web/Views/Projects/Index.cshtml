@model Aimbys.Web.ViewModels.Projects.ProjectIndexViewModel
@{
    ViewData["Title"] = "Projects";
}

<section class="container">
    @if (TempData["StatusMessage"] is string status)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @status
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-3 gap-2">
        <div>
            <h1 class="h3 fw-bold mb-1">Projects</h1>
            <p class="text-secondary small mb-0">
                @Model.TotalCount project@(Model.TotalCount == 1 ? "" : "s")@(Model.IncludeArchived ? " (including archived)" : "")
            </p>
        </div>
        <div>
            <a class="btn btn-primary" asp-action="Create">
                <span aria-hidden="true">+</span> New project
            </a>
        </div>
    </div>

    <form asp-action="Index" method="get" class="row g-2 mb-4" role="search">
        <div class="col-12 col-md-6 col-lg-5">
            <label for="q" class="visually-hidden">Search projects</label>
            <input type="search" class="form-control" id="q" name="q"
                   value="@Model.Query" placeholder="Search by name or description" />
        </div>
        <div class="col-auto d-flex align-items-center">
            <div class="form-check">
                <input type="checkbox" class="form-check-input" id="includeArchived"
                       name="includeArchived" value="true" @(Model.IncludeArchived ? "checked" : null) />
                <label class="form-check-label" for="includeArchived">Include archived</label>
            </div>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-primary">Search</button>
        </div>
    </form>

    @if (!Model.Projects.Any())
    {
        <div class="bg-body rounded shadow-sm border p-4 p-md-5 text-center">
            <h2 class="h5 fw-semibold mb-2">No projects yet</h2>
            <p class="text-secondary mb-3">
                @(string.IsNullOrEmpty(Model.Query)
                    ? "Create your first project to start drafting documents."
                    : "No projects match your search.")
            </p>
            <a class="btn btn-primary" asp-action="Create">Create a project</a>
        </div>
    }
    else
    {
        <div class="table-responsive bg-body rounded shadow-sm border">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col" class="d-none d-md-table-cell">Description</th>
                        <th scope="col" class="d-none d-lg-table-cell">Updated</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in Model.Projects)
                {
                    <tr>
                        <td>
                            <a class="fw-semibold text-decoration-none"
                               asp-action="Details" asp-route-id="@p.Id">@p.Name</a>
                            @if (p.IsArchived)
                            {
                                <span class="badge text-bg-secondary ms-2">Archived</span>
                            }
                        </td>
                        <td class="d-none d-md-table-cell text-secondary">
                            @if (string.IsNullOrWhiteSpace(p.Description))
                            {
                                <span class="text-body-tertiary">&mdash;</span>
                            }
                            else
                            {
                                @(p.Description.Length > 120 ? p.Description.Substring(0, 117) + "…" : p.Description)
                            }
                        </td>
                        <td class="d-none d-lg-table-cell text-secondary small">
                            @p.UpdatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary"
                               asp-action="Edit" asp-route-id="@p.Id">Edit</a>
                            <a class="btn btn-sm btn-outline-danger"
                               asp-action="Delete" asp-route-id="@p.Id">Delete</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        @if (Model.TotalCount > Model.Projects.Count)
        {
            <p class="text-secondary small mt-2 mb-0">
                Showing the most recently updated @Model.Projects.Count of @Model.TotalCount.
                Refine the search to see older items.
            </p>
        }
    }
</section>
