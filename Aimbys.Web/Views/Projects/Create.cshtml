@model Aimbys.Web.ViewModels.Projects.ProjectFormViewModel
@{
    ViewData["Title"] = "New project";
}

<section class="container">
    <nav aria-label="breadcrumb" class="small mb-2">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a class="text-decoration-none" asp-action="Index">Projects</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">New</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="bg-body rounded shadow-sm border p-4 p-md-5">
                <h1 class="h4 fw-bold mb-3">New project</h1>
                <partial name="_ProjectForm" model="Model" />
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
