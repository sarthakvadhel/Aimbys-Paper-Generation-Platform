@model IReadOnlyList<Aimbys.Domain.Entities.Notification>
@using Aimbys.Domain.Enums
@{
    ViewData["Title"] = "Notifications";
    var unread = (int)(ViewData["UnreadCount"] ?? 0);
    var currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    var severityFilter = ViewData["SeverityFilter"] as NotificationSeverity?;
}

<section class="container">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
        <div>
            <h1 class="h3 fw-bold mb-1">Notifications</h1>
            <p class="text-secondary small mb-0">@unread unread</p>
        </div>
        @if (unread > 0)
        {
            <form asp-action="MarkAllRead" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary btn-sm">Mark all read</button>
            </form>
        }
    </div>

    <form asp-action="Index" method="get" class="row g-2 mb-4" role="search">
        <div class="col-auto">
            <select name="severity" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All severities</option>
                @foreach (var s in Enum.GetValues<NotificationSeverity>())
                {
                    <option value="@((int)s)" selected="@(severityFilter == s)">@s</option>
                }
            </select>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="bg-body rounded shadow-sm border p-4 text-center">
            <p class="text-secondary mb-0">No notifications.</p>
        </div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var n in Model)
            {
                var alertClass = n.Severity switch
                {
                    NotificationSeverity.Success => "list-group-item-success",
                    NotificationSeverity.Warning => "list-group-item-warning",
                    NotificationSeverity.Error => "list-group-item-danger",
                    _ => ""
                };
                <div class="list-group-item @alertClass @(n.IsRead ? "opacity-75" : "")">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            @if (!string.IsNullOrEmpty(n.RouteUrl))
                            {
                                <a href="@n.RouteUrl" class="fw-semibold text-decoration-none">@n.Title</a>
                            }
                            else
                            {
                                <span class="fw-semibold">@n.Title</span>
                            }
                            @if (!string.IsNullOrEmpty(n.Body))
                            {
                                <p class="text-secondary small mb-0 mt-1">@n.Body</p>
                            }
                            <small class="text-body-tertiary">@n.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</small>
                        </div>
                        @if (!n.IsRead)
                        {
                            <form asp-action="MarkRead" method="post" class="ms-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@n.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Read</button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>

        @if (Model.Count >= 20)
        {
            <nav class="mt-3" aria-label="Notifications pagination">
                <a class="btn btn-outline-primary btn-sm"
                   asp-action="Index"
                   asp-route-page="@(currentPage + 1)"
                   asp-route-severity="@((int?)severityFilter)">
                    Next page &rarr;
                </a>
            </nav>
        }
    }
</section>
