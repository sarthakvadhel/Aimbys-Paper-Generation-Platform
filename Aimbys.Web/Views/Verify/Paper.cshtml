@model Aimbys.Application.Verification.QrVerificationResult
@{
    Layout = null;
    ViewData["Title"] = "Paper Verification";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Paper Verification — AIMBYS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width:600px;">
        <div class="card shadow-sm">
            <div class="card-body text-center p-4">
                @if (Model.IsValid)
                {
                    <div class="text-success mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM6.97 11.03a.75.75 0 0 0 1.07 0l3.992-3.992a.75.75 0 0 0-1.071-1.071L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06l2.646 2.647z"/>
                        </svg>
                    </div>
                    <h2 class="h4 text-success fw-bold">Valid Paper</h2>
                    <p class="text-secondary">This document has been verified as authentic.</p>
                    <dl class="text-start mt-3">
                        <dt>Paper</dt><dd>@Model.PaperTitle</dd>
                        <dt>Institute</dt><dd>@Model.InstituteName</dd>
                        <dt>Generated</dt><dd>@Model.GeneratedAtUtc?.ToString("yyyy-MM-dd HH:mm UTC")</dd>
                    </dl>
                }
                else
                {
                    <div class="text-danger mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293 5.354 4.646z"/>
                        </svg>
                    </div>
                    <h2 class="h4 text-danger fw-bold">Invalid / Tampered</h2>
                    <p class="text-secondary">This document could not be verified. It may have been tampered with or the token is invalid.</p>
                    @if (!string.IsNullOrEmpty(Model.Reason))
                    {
                        <p class="small text-secondary">@Model.Reason</p>
                    }
                }
            </div>
        </div>
        <p class="text-center text-secondary small mt-3">AIMBYS Paper Generation Platform</p>
    </div>
</body>
</html>
