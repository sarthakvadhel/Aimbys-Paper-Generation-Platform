@{
    ViewData["Title"] = "Dashboard";
}

@*
    Reached via /Student after a Student / Candidate signs in. Real
    student tooling (exam attempts, results, certificates, analytics)
    ships in Chunk 16+; this stub exists so the role shell and the
    post-login redirector have a target today.
*@

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Student dashboard</h1>
            <p class="text-secondary mb-0">
                Upcoming exams, results, and personal analytics.
            </p>
        </div>
        <span class="badge text-bg-primary">Coming in Chunk 16</span>
    </div>

    <div class="row g-3">
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Upcoming exams</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Lands when Exam aggregate ships</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Average score</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Awaiting Result aggregate</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Recent results</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Lands with Result publication</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Notifications</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Inbox at /Notifications</div>
            </article>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-12">
            <article class="aimbys-feature-card p-4 bg-body">
                <h2 class="h5 fw-semibold">Welcome, @User.Identity?.Name</h2>
                <p class="text-secondary mb-0">
                    The exam attempt surface, results detail page, and
                    personal analytics land in Chunk&nbsp;16. The shell
                    and role authorization are live today.
                </p>
            </article>
        </div>
    </div>
</div>
