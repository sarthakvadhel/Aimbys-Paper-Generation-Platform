@{
    ViewData["Title"] = "Student";
}

@*
    Reached via /Student after a Student / Candidate signs in. Exam
    access, results, and certificates ship in later chunks; this
    stub exists today so the post-login redirector has a target.
*@

<section class="container">
    <nav aria-label="breadcrumb" class="small mb-2">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a class="text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Student</li>
        </ol>
    </nav>

    <div class="bg-body rounded shadow-sm border p-4 p-md-5">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <h1 class="h3 fw-bold mb-0">Student dashboard</h1>
            <span class="badge text-bg-primary">Student</span>
        </div>
        <p class="text-secondary mb-0">
            Welcome, <strong>@User.Identity?.Name</strong>. Exam access,
            results, and certificates ship in upcoming chunks. This page
            exists so the post-login redirect from Chunk&nbsp;14 has a
            target.
        </p>
    </div>
</section>
