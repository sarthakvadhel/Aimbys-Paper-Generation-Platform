@using Aimbys.Domain.Entities.Results
@model IEnumerable<Result>
@{
    ViewData["Title"] = "My Results";
}

<div class="container-fluid py-4">
    <h1 class="h3 mb-4">Published Results</h1>

    @if (!Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-file-earmark-text display-4 text-muted"></i>
                <p class="mt-3 text-muted">No published results yet.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var result in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">Attempt: @result.ExamAttemptId.ToString()[..8]…</h5>
                            <p class="card-text">
                                <strong>Score:</strong> @result.TotalScore / @result.MaxScore<br />
                                <strong>Percentage:</strong> @result.Percentage.ToString("F1")%<br />
                                <strong>Grade:</strong> @(result.Grade ?? "—")<br />
                                <strong>Rank:</strong> @(result.RankInBatch?.ToString() ?? "—")
                            </p>
                            <a asp-action="Details" asp-route-attemptId="@result.ExamAttemptId" class="btn btn-sm btn-outline-primary">
                                View Details
                            </a>
                        </div>
                        <div class="card-footer text-muted small">
                            Published @result.PublishedAtUtc?.ToString("g")
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
