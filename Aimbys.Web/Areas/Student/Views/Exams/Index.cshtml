@model Aimbys.Web.Areas.Student.Controllers.StudentExamsViewModel
@{
    ViewData["Title"] = "My Exams";
}

<div class="container-fluid py-4">
    <h4 class="mb-3">My Exams</h4>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @success
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <h5 class="mt-4 mb-2">Upcoming</h5>
    <div class="card shadow-sm mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Scheduled At</th>
                            <th>Duration</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exam in Model.Upcoming)
                        {
                            var hasAttempt = Model.Attempts.Any(a => a.ExamId == exam.Id);
                            <tr>
                                <td>@exam.Title</td>
                                <td>@exam.ScheduledAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                <td>@exam.DurationMinutes min</td>
                                <td><span class="badge bg-info">@exam.Status</span></td>
                                <td>
                                    @if (!hasAttempt)
                                    {
                                        <form asp-action="Start" method="post" class="d-inline">
                                            <input type="hidden" name="examId" value="@exam.Id" />
                                            <button type="submit" class="btn btn-sm btn-success">Start</button>
                                        </form>
                                    }
                                    else
                                    {
                                        var attempt = Model.Attempts.First(a => a.ExamId == exam.Id);
                                        if (attempt.Status == Aimbys.Domain.Enums.AttemptStatus.InProgress)
                                        {
                                            <a asp-action="Take" asp-route-attemptId="@attempt.Id" class="btn btn-sm btn-warning">Resume</a>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@attempt.Status</span>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Upcoming.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-3">No upcoming exams.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <h5 class="mt-4 mb-2">Completed</h5>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Date</th>
                            <th>Score</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exam in Model.Completed)
                        {
                            var attempt = Model.Attempts.FirstOrDefault(a => a.ExamId == exam.Id);
                            <tr>
                                <td>@exam.Title</td>
                                <td>@exam.ScheduledAtUtc.ToString("yyyy-MM-dd")</td>
                                <td>@(attempt?.TotalAutoScore?.ToString("F2") ?? "—")</td>
                                <td><span class="badge bg-success">@(attempt?.Status.ToString() ?? "—")</span></td>
                            </tr>
                        }
                        @if (!Model.Completed.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">No completed exams.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
