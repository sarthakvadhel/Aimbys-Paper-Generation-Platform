@model IReadOnlyList<Aimbys.Domain.Entities.Broadcasts.Broadcast>
@{
    ViewData["Title"] = "Broadcasts";
    var status = TempData["StatusMessage"] as string;
    var nowUtc = DateTime.UtcNow;
}

@*
    SuperAdmin broadcasts listing (Chunk 35). Shows each broadcast's
    active window, audience JSON, and current status. The "Cancel"
    button posts to BroadcastsController.Cancel with anti-forgery.
*@

<div class="container-fluid py-4 px-3 px-md-4">

    <header class="mb-4 d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div>
            <div class="text-secondary small text-uppercase" style="letter-spacing: 0.08em;">SuperAdmin / Governance</div>
            <h1 class="h3 fw-bold mt-1 mb-0">Broadcasts</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">+ New Broadcast</a>
    </header>

    @if (!string.IsNullOrEmpty(status))
    {
        <div class="alert alert-success" role="status">@status</div>
    }

    <article class="aimbys-chart-card bg-body border rounded-3 p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Subject</th>
                        <th scope="col">Active window (UTC)</th>
                        <th scope="col">Audience</th>
                        <th scope="col">Status</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center text-secondary py-4">
                                No broadcasts yet. Use <em>+ New Broadcast</em> to schedule one.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var b in Model)
                        {
                            var live = b.IsActive && b.StartsAtUtc <= nowUtc && b.EndsAtUtc > nowUtc;
                            var pending = b.IsActive && b.StartsAtUtc > nowUtc;
                            <tr>
                                <td>
                                    <div class="fw-semibold">@b.Subject</div>
                                    <div class="text-secondary small font-monospace">@b.Id</div>
                                </td>
                                <td class="font-monospace small">
                                    @b.StartsAtUtc.ToString("yyyy-MM-dd HH:mm")
                                    <span class="text-secondary">→</span>
                                    @b.EndsAtUtc.ToString("yyyy-MM-dd HH:mm")
                                </td>
                                <td>
                                    <code class="small">@b.AudienceFilterJson</code>
                                </td>
                                <td>
                                    @if (!b.IsActive)
                                    {
                                        <span class="badge text-bg-secondary">Cancelled</span>
                                    }
                                    else if (live)
                                    {
                                        <span class="badge text-bg-success">Live</span>
                                    }
                                    else if (pending)
                                    {
                                        <span class="badge text-bg-info">Scheduled</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">Expired</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (b.IsActive && b.EndsAtUtc > nowUtc)
                                    {
                                        <form asp-action="Cancel" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@b.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Cancel this broadcast?');">
                                                Cancel
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </article>

</div>
