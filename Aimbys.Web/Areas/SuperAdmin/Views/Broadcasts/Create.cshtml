@model Aimbys.Web.Areas.SuperAdmin.ViewModels.BroadcastCreateViewModel
@{
    ViewData["Title"] = "New Broadcast";
}

@*
    Create-broadcast form (Chunk 35). Plain HTML inputs only — body
    HTML is sanitised on the server before persistence, so the
    textarea is intentionally raw for V1. The audience JSON textarea
    has a small helper hint reminding the operator of the supported
    keys.
*@

<div class="container-fluid py-4 px-3 px-md-4">

    <header class="mb-4">
        <div class="text-secondary small text-uppercase" style="letter-spacing: 0.08em;">SuperAdmin / Governance</div>
        <h1 class="h3 fw-bold mt-1 mb-0">New broadcast</h1>
    </header>

    <article class="aimbys-chart-card bg-body border rounded-3 p-3 p-md-4" style="max-width: 820px;">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Subject" class="form-label fw-semibold">Subject</label>
                <input asp-for="Subject" class="form-control" maxlength="200" required />
                <span asp-validation-for="Subject" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BodyHtml" class="form-label fw-semibold">Body (HTML)</label>
                <textarea asp-for="BodyHtml" class="form-control font-monospace" rows="6"
                          placeholder="&lt;p&gt;Scheduled maintenance on Sunday 02:00 UTC&lt;/p&gt;"></textarea>
                <div class="form-text">
                    Body is sanitised server-side on save. Scripts and inline event handlers are stripped.
                </div>
                <span asp-validation-for="BodyHtml" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AudienceFilterJson" class="form-label fw-semibold">Audience filter (JSON)</label>
                <textarea asp-for="AudienceFilterJson" class="form-control font-monospace" rows="3"></textarea>
                <div class="form-text">
                    Supported keys today: <code>roles</code>. Example:
                    <code>{"roles":["all"]}</code> &mdash;
                    <code>{"roles":["Teacher","Student"]}</code>.
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-12 col-md-6">
                    <label asp-for="StartsAtUtc" class="form-label fw-semibold">Starts (UTC)</label>
                    <input asp-for="StartsAtUtc" type="datetime-local" class="form-control" required />
                    <span asp-validation-for="StartsAtUtc" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="EndsAtUtc" class="form-label fw-semibold">Ends (UTC)</label>
                    <input asp-for="EndsAtUtc" type="datetime-local" class="form-control" required />
                    <span asp-validation-for="EndsAtUtc" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Schedule broadcast</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </article>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
