@{
    ViewData["Title"] = "Dashboard";
}

@*
    Reached via /SuperAdmin after sign-in. Real platform tooling
    (institute approvals, audit-log viewer, system health) ships in
    Chunk 16+. This stub exists so the post-login redirector and the
    sidebar's "Dashboard" link have a target today.
*@

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Super Admin dashboard</h1>
            <p class="text-secondary mb-0">
                Platform-wide governance, tenant management, and system health.
            </p>
        </div>
        <span class="badge text-bg-primary">Coming in Chunk 16</span>
    </div>

    <div class="row g-3">
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Institutes</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Awaiting Institute aggregate</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Pending approvals</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Awaiting Institute approval workflow</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Workflow events</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Wired up in Chunk 16</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Audit entries</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Audit viewer ships later</div>
            </article>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-12">
            <article class="aimbys-feature-card p-4 bg-body">
                <h2 class="h5 fw-semibold">Welcome, @User.Identity?.Name</h2>
                <p class="text-secondary mb-0">
                    The full SuperAdmin dashboard &mdash; institute approvals,
                    cross-tenant analytics, audit-log viewer, system health
                    panels &mdash; lands in Chunk&nbsp;16. The shell, navigation,
                    and authorization gates are live today.
                </p>
            </article>
        </div>
    </div>
</div>
