@using Aimbys.Domain.Enums
@model Aimbys.Web.Areas.SuperAdmin.ViewModels.AuditIndexViewModel
@{
    ViewData["Title"] = "Audit Logs";
    var severityValues = Enum.GetValues<AuditSeverity>();
}

@*
    SuperAdmin audit-log viewer (Chunk 35). Filter form on top, "Export
    CSV" alongside; paginated table below. Visibility/masking counters
    are surfaced so reviewers know when rows are being hidden.
*@

<div class="container-fluid py-4 px-3 px-md-4">

    <header class="mb-4 d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div>
            <div class="text-secondary small text-uppercase" style="letter-spacing: 0.08em;">SuperAdmin / Governance</div>
            <h1 class="h3 fw-bold mt-1 mb-0">Audit Logs</h1>
        </div>
        <a class="btn btn-outline-primary"
           asp-action="Export"
           asp-route-severity="@Model.Severity"
           asp-route-entityType="@Model.EntityType"
           asp-route-search="@Model.Search">
            Export CSV
        </a>
    </header>

    <article class="aimbys-chart-card bg-body border rounded-3 p-3 p-md-4 mb-4">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-12 col-md-3">
                <label for="audit-severity" class="form-label small fw-semibold mb-1">Severity</label>
                <select id="audit-severity" name="severity" class="form-select">
                    <option value="">All severities</option>
                    @foreach (var sev in severityValues)
                    {
                        if (Model.Severity == sev)
                        {
                            <option value="@sev" selected>@sev</option>
                        }
                        else
                        {
                            <option value="@sev">@sev</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label for="audit-entityType" class="form-label small fw-semibold mb-1">Entity type</label>
                <select id="audit-entityType" name="entityType" class="form-select">
                    <option value="">All entities</option>
                    @foreach (var et in Model.EntityTypes)
                    {
                        if (string.Equals(Model.EntityType, et, StringComparison.Ordinal))
                        {
                            <option value="@et" selected>@et</option>
                        }
                        else
                        {
                            <option value="@et">@et</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label for="audit-search" class="form-label small fw-semibold mb-1">Search</label>
                <input id="audit-search" name="search" type="search" class="form-control"
                       placeholder="Action, entity id, or details..." value="@Model.Search" />
            </div>
            <div class="col-12 col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
            </div>
        </form>
    </article>

    @if (Model.HiddenCount > 0 || Model.MaskedCount > 0)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2 mb-3" role="status">
            <span class="fw-semibold">Visibility policy:</span>
            <span>@Model.HiddenCount entries hidden</span>
            <span class="text-secondary">·</span>
            <span>@Model.MaskedCount entries masked</span>
        </div>
    }

    <article class="aimbys-chart-card bg-body border rounded-3 p-0 mb-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Occurred (UTC)</th>
                        <th scope="col">Severity</th>
                        <th scope="col">Action</th>
                        <th scope="col">Entity</th>
                        <th scope="col">Actor</th>
                        <th scope="col">IP</th>
                        <th scope="col">Details</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-secondary py-4">No audit entries match the current filter.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td><code>@row.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</code></td>
                                <td>
                                    @switch (row.Severity)
                                    {
                                        case AuditSeverity.Error:
                                            <span class="badge text-bg-danger">@row.Severity</span>
                                            break;
                                        case AuditSeverity.Warning:
                                            <span class="badge text-bg-warning">@row.Severity</span>
                                            break;
                                        default:
                                            <span class="badge text-bg-secondary">@row.Severity</span>
                                            break;
                                    }
                                </td>
                                <td>@row.Action</td>
                                <td>
                                    <div class="small fw-semibold">@row.EntityType</div>
                                    <div class="text-secondary small font-monospace">@row.EntityId</div>
                                </td>
                                <td class="font-monospace small">@(row.ActorUserId ?? "—")</td>
                                <td class="font-monospace small">@(row.IpAddress ?? "—")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(row.DetailsJson))
                                    {
                                        <details>
                                            <summary class="small">view</summary>
                                            <pre class="small mb-0 mt-2 text-wrap">@row.DetailsJson</pre>
                                        </details>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </article>

    <nav aria-label="Audit log pagination" class="d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div class="text-secondary small">
            Showing @(Model.Rows.Count) of @Model.TotalCount entries · Page @Model.Page of @Math.Max(1, Model.TotalPages)
        </div>
        <ul class="pagination mb-0">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-severity="@Model.Severity"
                   asp-route-entityType="@Model.EntityType"
                   asp-route-search="@Model.Search"
                   asp-route-page="@(Model.Page - 1)"
                   asp-route-pageSize="@Model.PageSize">Previous</a>
            </li>
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-severity="@Model.Severity"
                   asp-route-entityType="@Model.EntityType"
                   asp-route-search="@Model.Search"
                   asp-route-page="@(Model.Page + 1)"
                   asp-route-pageSize="@Model.PageSize">Next</a>
            </li>
        </ul>
    </nav>

</div>
