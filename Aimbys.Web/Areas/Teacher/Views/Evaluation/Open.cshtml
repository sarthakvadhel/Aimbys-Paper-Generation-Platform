@model Aimbys.Application.Evaluation.EvaluationContext
@{
    ViewData["Title"] = "Score Evaluation";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Score Evaluation</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Desk
        </a>
    </div>

    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        @* Left panel: student answer *@
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Student Answer</h5>
                </div>
                <div class="card-body">
                    @if (Model.AnswerJson is not null)
                    {
                        <pre class="bg-light p-3 rounded">@Model.AnswerJson</pre>
                    }
                    else
                    {
                        <p class="text-muted">Answer content will appear here once linked.</p>
                    }
                </div>
            </div>
        </div>

        @* Right panel: rubric scoring grid *@
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Rubric Scoring</h5>
                </div>
                <div class="card-body">
                    @if (Model.CriteriaJson is not null)
                    {
                        <p class="text-muted small">Criteria loaded from scoring scheme.</p>
                    }
                    else
                    {
                        <p class="text-muted small">No scoring scheme linked yet. Enter scores manually below.</p>
                    }

                    <div id="draftScoresContainer">
                        @foreach (var draft in Model.DraftScores)
                        {
                            <div class="mb-3 row align-items-center draft-score-row" data-index="@draft.CriterionIndex">
                                <label class="col-sm-4 col-form-label">Criterion @draft.CriterionIndex</label>
                                <div class="col-sm-8">
                                    <input type="number" step="0.01" class="form-control draft-score-input"
                                           value="@draft.PointsAwarded"
                                           data-evaluation-id="@Model.EvaluationId"
                                           data-criterion-index="@draft.CriterionIndex" />
                                </div>
                            </div>
                        }
                        @if (!Model.DraftScores.Any())
                        {
                            <div class="mb-3 row align-items-center draft-score-row" data-index="0">
                                <label class="col-sm-4 col-form-label">Criterion 0</label>
                                <div class="col-sm-8">
                                    <input type="number" step="0.01" class="form-control draft-score-input"
                                           value="0"
                                           data-evaluation-id="@Model.EvaluationId"
                                           data-criterion-index="0" />
                                </div>
                            </div>
                        }
                    </div>

                    <hr />
                    <h6>Feedback</h6>
                    <textarea id="feedbackTextarea" class="form-control mb-3" rows="4"
                              data-evaluation-id="@Model.EvaluationId"
                              placeholder="Enter feedback for the student...">@Model.Feedback</textarea>

                    <form asp-action="Submit" method="post">
                        <input type="hidden" name="evaluationId" value="@Model.EvaluationId" />
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-check-circle"></i> Submit Evaluation
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Autosave draft scores on change
    document.querySelectorAll('.draft-score-input').forEach(input => {
        input.addEventListener('change', async function () {
            const evaluationId = this.dataset.evaluationId;
            const criterionIndex = parseInt(this.dataset.criterionIndex);
            const points = parseFloat(this.value) || 0;
            await fetch('@Url.Action("SaveDraftScore")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ evaluationId, criterionIndex, points })
            });
        });
    });

    // Autosave feedback on blur
    document.getElementById('feedbackTextarea')?.addEventListener('blur', async function () {
        const evaluationId = this.dataset.evaluationId;
        const feedback = this.value;
        await fetch('@Url.Action("SaveFeedback")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ evaluationId, feedback })
        });
    });
</script>
}
