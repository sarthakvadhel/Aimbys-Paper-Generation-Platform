@model IEnumerable<Aimbys.Domain.Entities.Evaluation.Evaluation>
@{
    ViewData["Title"] = "Evaluation Desk";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0"><i class="bi bi-pen me-2"></i>Evaluation Desk</h2>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm @(ViewContext.HttpContext.Request.Query["status"].Count == 0 ? "active" : "")">All</a>
            <a asp-action="Index" asp-route-status="Pending" class="btn btn-outline-warning btn-sm">Pending</a>
            <a asp-action="Index" asp-route-status="InProgress" class="btn btn-outline-info btn-sm">In Progress</a>
            <a asp-action="Index" asp-route-status="Submitted" class="btn btn-outline-success btn-sm">Submitted</a>
        </div>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @success
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0" id="evaluationsTable">
                <thead class="table-light">
                    <tr>
                        <th>Evaluation ID</th>
                        <th>Status</th>
                        <th>Assigned</th>
                        <th>Completed</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var eval in Model)
                    {
                        <tr>
                            <td><code>@eval.Id.ToString()[..8]…</code></td>
                            <td>
                                @switch (eval.Status)
                                {
                                    case Aimbys.Domain.Enums.EvaluationStatus.Pending:
                                        <span class="badge bg-warning text-dark">Pending</span>
                                        break;
                                    case Aimbys.Domain.Enums.EvaluationStatus.InProgress:
                                        <span class="badge bg-info">In Progress</span>
                                        break;
                                    case Aimbys.Domain.Enums.EvaluationStatus.Submitted:
                                        <span class="badge bg-success">Submitted</span>
                                        break;
                                    case Aimbys.Domain.Enums.EvaluationStatus.Returned:
                                        <span class="badge bg-danger">Returned</span>
                                        break;
                                }
                            </td>
                            <td>@eval.AssignedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(eval.CompletedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                            <td>
                                @if (eval.Status != Aimbys.Domain.Enums.EvaluationStatus.Submitted)
                                {
                                    <a asp-action="Open" asp-route-evaluationId="@eval.Id"
                                       class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil-square"></i> Score
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="Open" asp-route-evaluationId="@eval.Id"
                                       class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                No evaluations assigned yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
