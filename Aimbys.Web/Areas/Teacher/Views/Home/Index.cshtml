@{
    ViewData["Title"] = "Dashboard";
}

@*
    Reached via /Teacher after a Teacher / Examiner signs in. Paper
    authoring, evaluation queues, and moderation surfaces ship in
    Chunk 16+; this stub exists today so the post-login redirector
    has a target and the role-area authorization is exercised.
*@

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Teacher dashboard</h1>
            <p class="text-secondary mb-0">
                Authoring, evaluation queues, and reports.
            </p>
        </div>
        <span class="badge text-bg-primary">Coming in Chunk 16</span>
    </div>

    <div class="row g-3">
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Drafts</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Awaiting Paper aggregate</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Evaluations due</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Workflow queue ships later</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Moderation</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Workflow-engine wired (Chunk 11)</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Notifications</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Inbox at /Notifications</div>
            </article>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-12">
            <article class="aimbys-feature-card p-4 bg-body">
                <h2 class="h5 fw-semibold">Welcome, @User.Identity?.Name</h2>
                <p class="text-secondary mb-0">
                    Paper authoring, evaluation desk, and reporting
                    surfaces land in Chunk&nbsp;16. The shell, role
                    permissions, and notification feed are live today.
                </p>
            </article>
        </div>
    </div>
</div>
