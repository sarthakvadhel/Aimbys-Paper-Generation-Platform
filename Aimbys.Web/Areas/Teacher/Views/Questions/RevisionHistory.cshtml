@model IReadOnlyList<Aimbys.Application.Questions.QuestionVersionSummary>
@{
    ViewData["Title"] = "Revision History";
    var questionId = (Guid)ViewBag.QuestionId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Revision History</h4>
    <a asp-action="Edit" asp-route-id="@questionId" class="btn btn-outline-primary">Back to Edit</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (!Model.Any())
        {
            <p class="text-muted text-center py-4">No version history found.</p>
        }
        else
        {
            <div class="list-group">
                @foreach (var version in Model)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center @(version.IsCurrentVersion ? "list-group-item-primary" : "")">
                        <div>
                            <strong>Version @version.VersionNumber</strong>
                            @if (version.IsCurrentVersion)
                            {
                                <span class="badge bg-success ms-2">Current</span>
                            }
                            <br />
                            <small class="text-muted">
                                Created @version.CreatedAtUtc.ToString("dd MMM yyyy HH:mm") UTC
                                &middot; Author: @version.AuthorUserId
                            </small>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
