@model Aimbys.Web.ViewModels.Questions.QuestionCreateViewModel
@{
    ViewData["Title"] = "Create Question";
}

<h4 class="mb-4">Create Question</h4>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label asp-for="Type" class="form-label">Question Type</label>
                    <select asp-for="Type" asp-items="Html.GetEnumSelectList<Aimbys.Domain.Enums.QuestionType>()" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="SubjectId" class="form-label">Subject</label>
                    <input asp-for="SubjectId" class="form-control" placeholder="Subject GUID" />
                </div>
                <div class="col-md-4">
                    <label asp-for="ChapterId" class="form-label">Chapter (optional)</label>
                    <input asp-for="ChapterId" class="form-control" placeholder="Chapter GUID" />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label asp-for="Difficulty" class="form-label">Difficulty</label>
                    <select asp-for="Difficulty" asp-items="Html.GetEnumSelectList<Aimbys.Domain.Enums.DifficultyLevel>()" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="BloomLevel" class="form-label">Bloom Level</label>
                    <select asp-for="BloomLevel" asp-items="Html.GetEnumSelectList<Aimbys.Domain.Enums.BloomLevel>()" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="Marks" class="form-label">Marks</label>
                    <input asp-for="Marks" class="form-control" type="number" step="0.5" />
                </div>
                <div class="col-md-3">
                    <label asp-for="EstimatedTimeMinutes" class="form-label">Time (min)</label>
                    <input asp-for="EstimatedTimeMinutes" class="form-control" type="number" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="BodyHtml" class="form-label">Question Body</label>
                <textarea asp-for="BodyHtml" class="form-control" rows="6" placeholder="Enter question HTML body..."></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="InstructionsHtml" class="form-label">Instructions (optional)</label>
                <textarea asp-for="InstructionsHtml" class="form-control" rows="3" placeholder="Special instructions..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Question</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
