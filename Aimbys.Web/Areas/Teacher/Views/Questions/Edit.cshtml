@model Aimbys.Web.ViewModels.Questions.QuestionEditViewModel
@{
    ViewData["Title"] = "Edit Question";
}

<h4 class="mb-4">Edit Question</h4>

@if (Model.Status == Aimbys.Domain.Enums.QuestionStatus.Approved || Model.Status == Aimbys.Domain.Enums.QuestionStatus.Retired)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-1"></i>
        This question is <strong>@Model.Status</strong>. Saving changes will create a new version.
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.QuestionId" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <span class="badge bg-secondary">@Model.Type</span>
                <span class="badge bg-info ms-1">@Model.Status</span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label asp-for="Difficulty" class="form-label">Difficulty</label>
                    <select asp-for="Difficulty" asp-items="Html.GetEnumSelectList<Aimbys.Domain.Enums.DifficultyLevel>()" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="BloomLevel" class="form-label">Bloom Level</label>
                    <select asp-for="BloomLevel" asp-items="Html.GetEnumSelectList<Aimbys.Domain.Enums.BloomLevel>()" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="Marks" class="form-label">Marks</label>
                    <input asp-for="Marks" class="form-control" type="number" step="0.5" />
                </div>
                <div class="col-md-3">
                    <label asp-for="EstimatedTimeMinutes" class="form-label">Time (min)</label>
                    <input asp-for="EstimatedTimeMinutes" class="form-control" type="number" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="BodyHtml" class="form-label">Question Body</label>
                <textarea asp-for="BodyHtml" class="form-control" rows="6"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="InstructionsHtml" class="form-label">Instructions (optional)</label>
                <textarea asp-for="InstructionsHtml" class="form-control" rows="3"></textarea>
            </div>

            <input type="hidden" asp-for="QuestionId" />
            <input type="hidden" asp-for="Type" />
            <input type="hidden" asp-for="Status" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <a asp-action="RevisionHistory" asp-route-id="@Model.QuestionId" class="btn btn-outline-info ms-auto">Version History</a>
            </div>
        </form>
    </div>
</div>
