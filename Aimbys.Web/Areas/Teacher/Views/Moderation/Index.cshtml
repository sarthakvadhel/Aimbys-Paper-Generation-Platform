@model IEnumerable<Aimbys.Domain.Entities.Moderation.Moderation>
@{
    ViewData["Title"] = "Moderation Inbox";
}

<div class="container-fluid py-4">
    <h2 class="mb-4">Moderation Inbox</h2>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible fade show">@success
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger alert-dismissible fade show">@error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <table class="table table-hover" id="moderationsTable">
                <thead>
                    <tr>
                        <th>Evaluation</th>
                        <th>Verdict</th>
                        <th>Assigned</th>
                        <th>Completed</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.EvaluationId.ToString()[..8]...</td>
                            <td>
                                <span class="badge bg-@(item.Verdict == Aimbys.Domain.Enums.ModerationVerdict.Pending ? "warning" : item.Verdict == Aimbys.Domain.Enums.ModerationVerdict.Approved ? "success" : "secondary")">
                                    @item.Verdict
                                </span>
                            </td>
                            <td>@item.AssignedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(item.CompletedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                            <td>
                                @if (item.Verdict == Aimbys.Domain.Enums.ModerationVerdict.Pending)
                                {
                                    <a asp-action="Open" asp-route-moderationId="@item.Id" class="btn btn-sm btn-primary">Open</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
