@model Aimbys.Application.Moderation.ModerationContext
@{
    ViewData["Title"] = "Moderation Review";
}

<div class="container-fluid py-4">
    <h2 class="mb-4">Moderation Review</h2>

    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger alert-dismissible fade show">@error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- Column 1: Answer -->
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header"><strong>Student Answer</strong></div>
                <div class="card-body">
                    <pre class="mb-0">@(Model.AnswerJson ?? "No answer data available.")</pre>
                </div>
            </div>
        </div>

        <!-- Column 2: Evaluator Scores -->
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header"><strong>Evaluator Scores</strong></div>
                <div class="card-body">
                    <pre class="mb-0">@(Model.EvaluatorScoresJson ?? "{}")</pre>
                    @if (Model.EvaluatedTotal.HasValue)
                    {
                        <hr />
                        <p><strong>Total:</strong> @Model.EvaluatedTotal / @Model.MaxPossible</p>
                    }
                </div>
            </div>
        </div>

        <!-- Column 3: Action Panel -->
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header"><strong>Actions</strong></div>
                <div class="card-body">
                    <p><strong>Verdict:</strong> <span class="badge bg-info">@Model.Verdict</span></p>

                    @if (Model.Verdict == Aimbys.Domain.Enums.ModerationVerdict.Pending)
                    {
                        <!-- Approve Form -->
                        <form asp-action="Approve" method="post" class="mb-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="moderationId" value="@Model.ModerationId" />
                            <button type="submit" class="btn btn-success w-100">Approve</button>
                        </form>

                        <!-- Require Changes Form -->
                        <form asp-action="RequireChanges" method="post" class="mb-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="moderationId" value="@Model.ModerationId" />
                            <div class="mb-2">
                                <textarea name="comment" class="form-control" rows="3" placeholder="Explain what needs to change..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-warning w-100">Require Changes</button>
                        </form>

                        <!-- Override Form -->
                        <form asp-action="Override" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="moderationId" value="@Model.ModerationId" />
                            <div class="mb-2">
                                <label class="form-label">New Score</label>
                                <input type="number" step="0.01" name="newScore" class="form-control" required />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Max Score</label>
                                <input type="number" step="0.01" name="maxScore" class="form-control" required />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Override Reason</label>
                                <textarea name="reason" class="form-control" rows="2" placeholder="Justification for the override..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-danger w-100">Override Score</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Inbox</a>
    </div>
</div>
