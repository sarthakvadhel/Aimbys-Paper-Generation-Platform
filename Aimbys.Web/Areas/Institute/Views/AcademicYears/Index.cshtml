@model IEnumerable<Aimbys.Domain.Entities.AcademicYear>
@{
    ViewData["Title"] = "Academic Years";
    var tableModel = new Aimbys.Web.Models.UI.DataTableModel(
        Caption: "Academic Years",
        Columns: new[]
        {
            new Aimbys.Web.Models.UI.DataTableColumn("Name"),
            new Aimbys.Web.Models.UI.DataTableColumn("Start"),
            new Aimbys.Web.Models.UI.DataTableColumn("End"),
            new Aimbys.Web.Models.UI.DataTableColumn("Current", Aimbys.Web.Models.UI.DataTableAlign.Center),
            new Aimbys.Web.Models.UI.DataTableColumn("Actions", Aimbys.Web.Models.UI.DataTableAlign.End)
        },
        Rows: Model.Select(y => new Aimbys.Web.Models.UI.DataTableRow(new Aimbys.Web.Models.UI.DataTableCell[]
        {
            new(y.Name),
            new(y.StartDate.ToString("yyyy-MM-dd")),
            new(y.EndDate.ToString("yyyy-MM-dd")),
            new(y.IsCurrent ? "<span class=\"badge bg-primary\">Current</span>" : "—", IsHtml: true),
            new($"<a href=\"#\" class=\"btn btn-sm btn-outline-primary\">Set Current</a>", IsHtml: true)
        })).ToList(),
        EmptyMessage: "No academic years configured yet.");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Academic Years</h4>
</div>

<partial name="_DataTable" model="tableModel" />
