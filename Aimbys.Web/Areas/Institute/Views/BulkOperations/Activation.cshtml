@model Aimbys.Web.Areas.Institute.ViewModels.BulkActivationViewModel
@{
    ViewData["Title"] = "Bulk Activation";
}

<div class="container-fluid py-4 px-3 px-md-4">
    <header class="mb-4">
        <div class="text-secondary small text-uppercase" style="letter-spacing:0.08em;">Institute / Bulk Operations</div>
        <h1 class="h3 fw-bold mt-1 mb-0">Bulk Activate / Deactivate</h1>
    </header>

    <article class="bg-body border rounded-3 p-3 p-md-4" style="max-width:720px;">
        <p class="text-secondary mb-3">Upload a CSV with a single column: <code>ProfileId</code>.</p>
        <a asp-action="ActivationTemplate" class="btn btn-sm btn-outline-secondary mb-3">Download template CSV</a>

        <form asp-action="Activation" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger small mb-2"></div>
            <div class="mb-3">
                <label class="form-label fw-semibold">CSV file (max 10MB)</label>
                <input type="file" name="file" class="form-control" accept=".csv,.xlsx" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold d-block">Action</label>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="activate" id="activate-true" value="true" checked />
                    <label class="form-check-label" for="activate-true">Activate</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="activate" id="activate-false" value="false" />
                    <label class="form-check-label" for="activate-false">Deactivate</label>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Process</button>
        </form>
    </article>

    <partial name="_BulkResult" model="@(new Aimbys.Web.Areas.Institute.ViewModels.BulkResultViewModel { HasResult = Model.HasResult, Succeeded = Model.Succeeded, Failed = Model.Failed, Total = Model.Total, Errors = Model.Errors })" />
</div>
