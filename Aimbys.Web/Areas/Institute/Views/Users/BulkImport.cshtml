@model Aimbys.Web.ViewModels.Users.BulkImportResultViewModel
@{
    ViewData["Title"] = "Bulk Import Students";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">Bulk Import Students</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">
                    Upload a CSV file with the header:
                    <code>Email,DisplayName,AdmissionNumber,RollNumber,ClassBatchName</code>
                </p>

                @if (TempData["Error"] is string error)
                {
                    <div class="alert alert-danger">@error</div>
                }

                <form asp-action="BulkImport" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="file" class="form-label">CSV File</label>
                        <input type="file" name="file" id="file" class="form-control" accept=".csv" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Import</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                    </div>
                </form>

                @if (Model.HasResult)
                {
                    <hr />
                    <div class="alert alert-info mt-3">
                        <strong>@Model.SuccessCount</strong> student(s) imported successfully.
                    </div>

                    @if (Model.Errors.Count > 0)
                    {
                        <div class="alert alert-warning">
                            <strong>@Model.Errors.Count error(s):</strong>
                            <ul class="mb-0 mt-2">
                                @foreach (var err in Model.Errors)
                                {
                                    <li>@err</li>
                                }
                            </ul>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
