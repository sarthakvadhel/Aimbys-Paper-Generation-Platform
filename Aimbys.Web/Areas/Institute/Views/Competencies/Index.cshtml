@model IEnumerable<Aimbys.Domain.Entities.Blueprints.Competency>
@{
    ViewData["Title"] = "Competencies";
    var tableModel = new Aimbys.Web.Models.UI.DataTableModel(
        Caption: "Competencies",
        Columns: new[]
        {
            new Aimbys.Web.Models.UI.DataTableColumn("Order", Aimbys.Web.Models.UI.DataTableAlign.Center),
            new Aimbys.Web.Models.UI.DataTableColumn("Name"),
            new Aimbys.Web.Models.UI.DataTableColumn("Code"),
            new Aimbys.Web.Models.UI.DataTableColumn("Actions", Aimbys.Web.Models.UI.DataTableAlign.End)
        },
        Rows: Model.Select(c => new Aimbys.Web.Models.UI.DataTableRow(new Aimbys.Web.Models.UI.DataTableCell[]
        {
            new(c.SortOrder.ToString()),
            new(c.Name),
            new(c.Code ?? "—"),
            new($"<button class=\"btn btn-sm btn-outline-secondary\">Edit</button>", IsHtml: true)
        })).ToList(),
        EmptyMessage: "No competencies defined yet.");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Competencies</h4>
</div>

<form asp-action="Create" method="post" class="row g-2 mb-3 align-items-end">
    <div class="col-auto">
        <input type="text" name="name" class="form-control" placeholder="Name" required />
    </div>
    <div class="col-auto">
        <input type="text" name="code" class="form-control" placeholder="Code (optional)" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary btn-sm">Add</button>
    </div>
</form>

<partial name="_DataTable" model="tableModel" />
