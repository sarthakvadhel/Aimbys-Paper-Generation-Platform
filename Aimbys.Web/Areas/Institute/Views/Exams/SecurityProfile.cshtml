@model Aimbys.Domain.Entities.Exams.ExamSecurityProfile

@{
    ViewData["Title"] = "Exam Security Profile";
}

<div class="container mx-auto max-w-2xl py-8">
    <h1 class="text-2xl font-bold mb-6">Exam Security Profile</h1>

    @if (TempData["Success"] is string msg)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">@msg</div>
    }

    <form method="post" asp-action="SecurityProfile" asp-area="Institute" asp-controller="Exams">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ExamId" />

        <div class="space-y-4">
            <label class="flex items-center gap-2">
                <input type="checkbox" asp-for="RequireFullscreen" class="rounded" />
                <span>Require Fullscreen Mode</span>
            </label>

            <label class="flex items-center gap-2">
                <input type="checkbox" asp-for="DetectTabSwitch" class="rounded" />
                <span>Detect Tab Switching</span>
            </label>

            <label class="flex items-center gap-2">
                <input type="checkbox" asp-for="DetectResize" class="rounded" />
                <span>Detect Browser Resize</span>
            </label>

            <label class="flex items-center gap-2">
                <input type="checkbox" asp-for="BlockCopyPaste" class="rounded" />
                <span>Block Copy/Paste</span>
            </label>

            <label class="flex items-center gap-2">
                <input type="checkbox" asp-for="BlockKeyboardShortcuts" class="rounded" />
                <span>Block Keyboard Shortcuts</span>
            </label>

            <label class="flex items-center gap-2">
                <input type="checkbox" asp-for="AutoSubmitOnTimeout" class="rounded" />
                <span>Auto-Submit on Connection Timeout</span>
            </label>

            <label class="flex items-center gap-2">
                <input type="checkbox" asp-for="TrackDevice" class="rounded" />
                <span>Track Device Fingerprint</span>
            </label>

            <label class="flex items-center gap-2">
                <input type="checkbox" asp-for="TrackSession" class="rounded" />
                <span>Track Session</span>
            </label>

            <div>
                <label class="block font-medium mb-1">Heartbeat Interval (seconds)</label>
                <input type="number" asp-for="HeartbeatIntervalSeconds" class="border rounded px-3 py-2 w-32" min="10" max="300" />
            </div>

            <div>
                <label class="block font-medium mb-1">Max Connection Loss (seconds)</label>
                <input type="number" asp-for="MaxConnectionLossSeconds" class="border rounded px-3 py-2 w-32" min="30" max="600" />
            </div>
        </div>

        <div class="mt-8">
            <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700">
                Save Security Profile
            </button>
        </div>
    </form>
</div>
