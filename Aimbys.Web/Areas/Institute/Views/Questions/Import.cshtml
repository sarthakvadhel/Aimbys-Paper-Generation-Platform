@{
    ViewData["Title"] = "Import Questions";
}

<h4 class="mb-4">Import Questions</h4>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Import" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label">Upload File (CSV/Excel)</label>
                <input type="file" name="file" class="form-control" accept=".csv,.xlsx,.xls" />
                <div class="form-text">Upload a CSV or Excel file with question data. Template available for download.</div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Import</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
