@model IEnumerable<Aimbys.Domain.Entities.Subject>
@{
    ViewData["Title"] = "Subjects";
    var tableModel = new Aimbys.Web.Models.UI.DataTableModel(
        Caption: "Subjects",
        Columns: new[]
        {
            new Aimbys.Web.Models.UI.DataTableColumn("Name"),
            new Aimbys.Web.Models.UI.DataTableColumn("Code"),
            new Aimbys.Web.Models.UI.DataTableColumn("Active", Aimbys.Web.Models.UI.DataTableAlign.Center),
            new Aimbys.Web.Models.UI.DataTableColumn("Actions", Aimbys.Web.Models.UI.DataTableAlign.End)
        },
        Rows: Model.Select(s => new Aimbys.Web.Models.UI.DataTableRow(new Aimbys.Web.Models.UI.DataTableCell[]
        {
            new(s.Name),
            new(s.Code ?? "—"),
            new(s.IsActive ? "<span class=\"badge bg-success\">Active</span>" : "<span class=\"badge bg-secondary\">Inactive</span>", IsHtml: true),
            new($"<a href=\"#\" class=\"btn btn-sm btn-outline-secondary\">Edit</a>", IsHtml: true)
        })).ToList(),
        EmptyMessage: "No subjects configured yet.");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Subjects</h4>
</div>

<partial name="_DataTable" model="tableModel" />
