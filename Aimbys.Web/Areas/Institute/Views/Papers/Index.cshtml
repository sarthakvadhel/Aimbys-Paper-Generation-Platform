@model IEnumerable<Aimbys.Domain.Entities.Papers.Paper>
@{
    ViewData["Title"] = "Paper Management";
    var tableModel = new Aimbys.Web.Models.UI.DataTableModel(
        Caption: "All Papers",
        Columns: new[]
        {
            new Aimbys.Web.Models.UI.DataTableColumn("Title"),
            new Aimbys.Web.Models.UI.DataTableColumn("Status"),
            new Aimbys.Web.Models.UI.DataTableColumn("Updated"),
            new Aimbys.Web.Models.UI.DataTableColumn("Actions", Aimbys.Web.Models.UI.DataTableAlign.End)
        },
        Rows: Model.Select(p =>
        {
            var version = p.Versions.FirstOrDefault(v => v.Id == p.CurrentVersionId);
            var title = version?.Title ?? "Untitled";
            var statusBadge = p.Status switch
            {
                Aimbys.Domain.Enums.PaperStatus.Draft => "<span class=\"badge bg-secondary\">Draft</span>",
                Aimbys.Domain.Enums.PaperStatus.SubmittedForApproval => "<span class=\"badge bg-warning text-dark\">Submitted</span>",
                Aimbys.Domain.Enums.PaperStatus.Approved => "<span class=\"badge bg-success\">Approved</span>",
                Aimbys.Domain.Enums.PaperStatus.Returned => "<span class=\"badge bg-danger\">Returned</span>",
                Aimbys.Domain.Enums.PaperStatus.Published => "<span class=\"badge bg-primary\">Published</span>",
                _ => "<span class=\"badge bg-dark\">Archived</span>"
            };
            var actions = "";
            if (p.Status == Aimbys.Domain.Enums.PaperStatus.SubmittedForApproval)
            {
                actions = $"<form method=\"post\" action=\"{Url.Action("Approve", "Papers", new { area = "Institute", id = p.Id })}\" class=\"d-inline\">"
                    + $"{Html.AntiForgeryToken()}"
                    + "<button type=\"submit\" class=\"btn btn-sm btn-success me-1\">Approve</button></form>"
                    + $"<button type=\"button\" class=\"btn btn-sm btn-outline-danger\" data-bs-toggle=\"modal\" data-bs-target=\"#returnModal-{p.Id}\">Return</button>";
            }
            return new Aimbys.Web.Models.UI.DataTableRow(new Aimbys.Web.Models.UI.DataTableCell[]
            {
                new(title),
                new(statusBadge, IsHtml: true),
                new(p.UpdatedAtUtc.ToString("yyyy-MM-dd HH:mm")),
                new(actions, IsHtml: true)
            });
        }).ToList(),
        EmptyMessage: "No papers found for this institute.");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Paper Management</h4>
</div>

<partial name="_DataTable" model="tableModel" />

@foreach (var p in Model.Where(p => p.Status == Aimbys.Domain.Enums.PaperStatus.SubmittedForApproval))
{
    <div class="modal fade" id="returnModal-@p.Id" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="Return" asp-route-id="@p.Id">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title">Return Paper</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label for="comment-@p.Id" class="form-label">Comment (required)</label>
                        <textarea class="form-control" id="comment-@p.Id" name="comment" rows="3" required></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Return to Author</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
