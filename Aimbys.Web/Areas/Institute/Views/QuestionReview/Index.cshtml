@model IEnumerable<Aimbys.Domain.Entities.Questions.QuestionReview>
@{
    ViewData["Title"] = "Pending Reviews";
    var tableModel = new Aimbys.Web.Models.UI.DataTableModel(
        Caption: "Pending Question Reviews",
        Columns: new[]
        {
            new Aimbys.Web.Models.UI.DataTableColumn("Question ID"),
            new Aimbys.Web.Models.UI.DataTableColumn("Assigned"),
            new Aimbys.Web.Models.UI.DataTableColumn("Status", Aimbys.Web.Models.UI.DataTableAlign.Center),
            new Aimbys.Web.Models.UI.DataTableColumn("Actions", Aimbys.Web.Models.UI.DataTableAlign.End)
        },
        Rows: Model.Select(r => new Aimbys.Web.Models.UI.DataTableRow(new Aimbys.Web.Models.UI.DataTableCell[]
        {
            new(r.QuestionId.ToString()[..8] + "..."),
            new(r.AssignedAtUtc.ToString("yyyy-MM-dd HH:mm")),
            new("<span class=\"badge bg-warning\">Pending</span>", IsHtml: true),
            new($"<a href=\"{Url.Action("Open", "QuestionReview", new { questionId = r.QuestionId })}\" class=\"btn btn-sm btn-primary\">Review</a>", IsHtml: true)
        })).ToList(),
        EmptyMessage: "No pending reviews.");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Pending Question Reviews</h4>
</div>

<partial name="_DataTable" model="tableModel" />
