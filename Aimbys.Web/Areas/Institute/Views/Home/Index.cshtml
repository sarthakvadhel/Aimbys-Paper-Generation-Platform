@{
    ViewData["Title"] = "Dashboard";
}

@*
    Reached via /Institute after an Institute Administrator signs in.
    The institute-management dashboard with departments / subjects /
    teacher invites / approval queues lands in Chunk 16+; this stub
    page exists today so the role shell, navigation, authorization,
    and SubscriptionEnforcementMiddleware gate are all exercised end-
    to-end.
*@

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Institute dashboard</h1>
            <p class="text-secondary mb-0">
                Departments, subjects, class batches, teachers, students.
            </p>
        </div>
        <span class="badge text-bg-primary">Coming in Chunk 16</span>
    </div>

    <div class="row g-3">
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Teachers</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Invitation flow lands later</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Students</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Bulk import is wired (Chunk 12)</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Pending approvals</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Awaiting paper / question workflows</div>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="aimbys-feature-card h-100 p-4 bg-body">
                <div class="text-secondary small text-uppercase fw-semibold">Active exams</div>
                <div class="display-6 fw-bolder mt-2">&mdash;</div>
                <div class="text-secondary small">Lands when Exam aggregate ships</div>
            </article>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-12">
            <article class="aimbys-feature-card p-4 bg-body">
                <h2 class="h5 fw-semibold">Welcome, @User.Identity?.Name</h2>
                <p class="text-secondary mb-0">
                    The institute administration dashboard &mdash; teacher
                    invites, department / subject / class management,
                    approval inboxes &mdash; lands in Chunk&nbsp;16. The
                    shell, navigation, and tenant-scoped authorization
                    are live today.
                </p>
            </article>
        </div>
    </div>
</div>
