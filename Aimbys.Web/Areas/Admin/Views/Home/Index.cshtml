@{
    ViewData["Title"] = "Admin";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<section class="container">
    <nav aria-label="breadcrumb" class="small mb-2">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a class="text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Admin</li>
        </ol>
    </nav>

    <div class="bg-body rounded shadow-sm border p-4 p-md-5">
        <h1 class="h3 fw-bold mb-3">Admin area</h1>
        <p class="text-secondary">
            You are signed in as <strong>@User.Identity?.Name</strong> with the
            <span class="badge text-bg-primary">Admin</span> role. Real admin
            features &mdash; user management, audit log viewer, system health
            &mdash; arrive in later chunks. This page exists to verify
            authorization works.
        </p>
    </div>
</section>
